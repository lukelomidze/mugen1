;Victory screen definition
;This is the screen that is shown when you win a match in arcade mode.
;It will not be displayed on the last match of arcade mode.
[Victory Screen]
enabled = 1
sounds.enabled = 0        ;Ikemen feature
time = 800                ;Time to show screen
fadein.time = 8
fadeout.time = 15
;Winner's portrait and name
p1.offset = 530,130
p1.spr = 9000,2
p1.facing = 1
p1.scale = .432,.43
p1.window = 0,0, 1256,720
p1.name.offset = 556,410
p1.name.font = 2,0,1
;Win quote text
winquote.text = "GET READY FOR THE NEXT BATTLE!" ;Default win quote text to show
winquote.offset = 40,454
winquote.spacing = 0, 0   ;Ikemen feature
winquote.font = 2,0,1
winquote.window = 0,0, 1256,720
winquote.textwrap = w     ;Word wrap
winquote.delay = 2        ;Ikemen feature
winquote.time = 0         ;Ikemen feature

