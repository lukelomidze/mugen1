no.scale = 1.0, 1.0
no.offset = 47, 80
no.active.text = "No"
no.active.font = 3,0,0
no.active.scale = 1.0, 1.0
no.active.offset = 47, 80
move.snd = 100, 0                 ;Ikemen feature
done.snd = 100, 1                 ;Ikemen feature
cancel.snd = 100, 2               ;Ikemen feature

;parameters used by both legacy and extended continue
fadein.time = 8                   ;Ikemen feature
fadein.col = 0, 0, 0              ;Ikemen feature
fadeout.time = 120                ;Ikemen feature
fadeout.col = 0, 0, 0             ;Ikemen feature
;overlay.window = 0, 0, 320, 240   ;Ikemen feature
overlay.col = 0, 0, 0             ;Ikemen feature
overlay.alpha = 0, 128            ;Ikemen feature
