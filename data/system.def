connecting.font = 2,0,0                               ;Ikemen feature
connecting.scale = 1.0, 1.0                           ;Ikemen feature
connecting.host.text = "Waiting for player 2... (%s)" ;Ikemen feature
connecting.join.text = "Now connecting to %s... (%s)" ;Ikemen feature
